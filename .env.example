# ─────────────────────────────────────────────
# Supabase (https://supabase.com)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Database (Supabase Postgres connection string)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# Dropbox Sign (formerly HelloSign)
# https://app.hellosign.com/api/reference
# ─────────────────────────────────────────────
HELLOSIGN_API_KEY=your-hellosign-api-key
HELLOSIGN_CLIENT_ID=your-hellosign-client-id
HELLOSIGN_WEBHOOK_SECRET=your-webhook-secret

# ─────────────────────────────────────────────
# QuickBooks Online (Intuit)
# https://developer.intuit.com
# ─────────────────────────────────────────────
QBO_CLIENT_ID=your-qbo-client-id
QBO_CLIENT_SECRET=your-qbo-client-secret
QBO_REALM_ID=your-qbo-realm-id
QBO_REDIRECT_URI=http://localhost:3000/api/integrations/qbo/callback
QBO_ENVIRONMENT=sandbox  # sandbox | production
QBO_WEBHOOK_VERIFIER_TOKEN=your-webhook-verifier-token

# ─────────────────────────────────────────────
# Twilio SMS
# https://twilio.com
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ─────────────────────────────────────────────
# Resend (transactional email)
# https://resend.com
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Water Systems

# ─────────────────────────────────────────────
# Google APIs
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar

# ─────────────────────────────────────────────
# Dropbox Storage
# https://www.dropbox.com/developers
# ─────────────────────────────────────────────
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_ACCESS_TOKEN=your-dropbox-access-token

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-32-char-secret-for-tokens
NODE_ENV=development
